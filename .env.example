# --- copy to .env and fill in. NEVER commit .env. ---
APP_ENV=dev
APP_NAME=crime-craft

# Backend toggle: when true, the app talks to real Catalyst services.
# When false, the app uses local in-memory stubs (good for unit tests + offline dev).
CATALYST_ENABLED=false

# --- Catalyst project config ---
# Get these from the Catalyst Console → Project Settings → SDK Credentials.
CATALYST_PROJECT_ID=
CATALYST_PROJECT_DOMAIN=
CATALYST_PROJECT_KEY=
CATALYST_ENVIRONMENT=development   # development | production
CATALYST_CLIENT_ID=
CATALYST_CLIENT_SECRET=
CATALYST_REFRESH_TOKEN=

# --- Local-dev JWT (only used when CATALYST_ENABLED=false) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# --- RAG ---
# `stub` runs the whole RAG pipeline with in-memory + deterministic stubs.
# Useful for local dev, tests, and CI. Set to `live` to wire real Qdrant + Anthropic.
RAG_PROVIDER=stub
RAG_TOP_K_DEFAULT=6

# --- LLM / Embeddings (used when RAG_PROVIDER=live) ---
# Decide: Zoho ZIA vs external. If external, residency review required.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL_ID=claude-sonnet-4-6
EMBEDDING_MODEL=BAAI/bge-m3

# Vector DB (Catalyst has no vector primitive — self-host Qdrant on a VM in the same region)
VECTOR_DB_URL=http://localhost:6333
