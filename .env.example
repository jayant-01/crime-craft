# --- copy to .env and fill in. NEVER commit .env. ---
APP_ENV=dev
APP_NAME=crime-craft

# Backend toggle: when true, the app talks to real Catalyst services.
# When false, the app uses local in-memory stubs (good for unit tests + offline dev).
CATALYST_ENABLED=false

# --- Catalyst project config ---
# Get these from the Catalyst Console → Project Settings → SDK Credentials.
CATALYST_PROJECT_ID=
CATALYST_PROJECT_DOMAIN=
CATALYST_PROJECT_KEY=
CATALYST_ENVIRONMENT=development   # development | production
CATALYST_CLIENT_ID=
CATALYST_CLIENT_SECRET=
CATALYST_REFRESH_TOKEN=

# --- Local-dev JWT (only used when CATALYST_ENABLED=false) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# --- RAG ---
# `stub` runs the whole RAG pipeline with in-memory + deterministic stubs.
# Useful for local dev, tests, and CI. Set to `live` to wire real Qdrant + Anthropic.
RAG_PROVIDER=stub
RAG_TOP_K_DEFAULT=6

# --- LLM ---
# LLM_PROVIDER selects the chat model:
#   anthropic  → Claude via the official SDK (requires RAG_PROVIDER=live)
#   openrouter → any OpenRouter model, incl. FREE `:free` tiers. Works even
#                with RAG_PROVIDER=stub, so you get real answers over the demo
#                data without standing up Qdrant + the embedding model.
#   (anything else / no key) → deterministic StubLLM
#
# For OpenRouter: create a key at https://openrouter.ai/keys, then set:
#   LLM_PROVIDER=openrouter
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL_ID=meta-llama/llama-3.3-70b-instruct:free   # or any :free model
# Other good free ids: deepseek/deepseek-chat-v3-0324:free,
#   google/gemini-2.0-flash-exp:free, qwen/qwen-2.5-72b-instruct:free
# (Free-tier availability changes — see https://openrouter.ai/models?max_price=0)
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL_ID=claude-sonnet-4-6

# --- Embeddings (used when RAG_PROVIDER=live) ---
EMBEDDING_MODEL=BAAI/bge-m3

# Vector DB (Catalyst has no vector primitive — self-host Qdrant on a VM in the same region)
VECTOR_DB_URL=http://localhost:6333
